---
# Embedded C / MISRA-inspired clang-tidy configuration
#
# References:
#   - MISRA C:2012 guidelines (mapped to available clang-tidy checks)
#   - CERT C Coding Standard
#   - Barr Embedded C Coding Standard
#
Checks: >
  -*,
  bugprone-assignment-in-if-condition,
  bugprone-branch-clone,
  bugprone-implicit-widening-of-multiplication-result,
  bugprone-integer-division,
  bugprone-macro-parentheses,
  bugprone-misplaced-widening-cast,
  bugprone-narrowing-conversions,
  bugprone-not-null-terminated-result,
  bugprone-redundant-branch-condition,
  bugprone-signed-char-misuse,
  bugprone-sizeof-expression,
  bugprone-suspicious-semicolon,
  bugprone-too-small-loop-variable,
  bugprone-undefined-memory-manipulation,
  bugprone-unused-return-value,
  cert-err34-c,
  cert-flp30-c,
  cert-str34-c,
  clang-analyzer-core.*,
  clang-analyzer-deadcode.*,
  clang-analyzer-security.*,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  clang-analyzer-unix.*,
  misc-redundant-expression,
  misc-unused-parameters,
  readability-braces-around-statements,
  readability-identifier-naming,
  readability-inconsistent-declaration-parameter-name,
  readability-isolate-declaration,
  readability-misleading-indentation,
  readability-non-const-parameter,
  readability-redundant-preprocessor

WarningsAsErrors: >
  bugprone-assignment-in-if-condition,
  bugprone-suspicious-semicolon,
  readability-identifier-naming,
  readability-misleading-indentation

# Only analyze project headers, not HAL/CMSIS/third-party
HeaderFilterRegex: '(include|src)/.*\.h$'

CheckOptions:
  # -----------------------------------------------------------------
  #  Naming conventions  (Barr / MISRA-inspired)
  # -----------------------------------------------------------------

  # Functions: snake_case  (e.g. esp8266_init, app_main)
  - { key: readability-identifier-naming.FunctionCase,               value: lower_case }

  # Typedefs: snake_case_t  (e.g. esp8266_t, app_state_t)
  - { key: readability-identifier-naming.TypedefCase,                value: lower_case }
  - { key: readability-identifier-naming.TypedefSuffix,              value: '_t'       }

  # Struct / union / enum tag names: lower_case
  - { key: readability-identifier-naming.StructCase,                 value: lower_case }
  - { key: readability-identifier-naming.UnionCase,                  value: lower_case }
  - { key: readability-identifier-naming.EnumCase,                   value: lower_case }

  # Enum constants: UPPER_CASE  (e.g. ESP8266_OK, APP_STATE_INIT)
  - { key: readability-identifier-naming.EnumConstantCase,           value: UPPER_CASE }

  # Macro definitions: UPPER_CASE  (e.g. CONFIG_WIFI_SSID)
  - { key: readability-identifier-naming.MacroDefinitionCase,        value: UPPER_CASE }

  # Static const (file-scope): UPPER_CASE  (e.g. AT_OK)
  - { key: readability-identifier-naming.StaticConstantCase,         value: UPPER_CASE }

  # Global const (extern): UPPER_CASE
  - { key: readability-identifier-naming.GlobalConstantCase,         value: UPPER_CASE }

  # Static variables (non-const, file-scope): lower_case  (e.g. g_uart)
  - { key: readability-identifier-naming.StaticVariableCase,         value: lower_case }

  # Global variables (extern, non-const): lower_case
  - { key: readability-identifier-naming.GlobalVariableCase,         value: lower_case }

  # Local variables and constants: lower_case
  - { key: readability-identifier-naming.LocalVariableCase,          value: lower_case }
  - { key: readability-identifier-naming.LocalConstantCase,          value: lower_case }
  - { key: readability-identifier-naming.LocalPointerCase,           value: lower_case }

  # Function parameters: lower_case  (e.g. dev, timeout_ms)
  - { key: readability-identifier-naming.ParameterCase,              value: lower_case }
  - { key: readability-identifier-naming.ConstantParameterCase,      value: lower_case }

  # Struct / union members: lower_case  (e.g. rx_buffer, state)
  - { key: readability-identifier-naming.MemberCase,                 value: lower_case }

  # -----------------------------------------------------------------
  #  Check-specific options
  # -----------------------------------------------------------------

  # Allow short variable names (i, n, ...) in loop counters
  - { key: readability-identifier-naming.LocalVariableMinimumLength,  value: '1' }
  - { key: readability-identifier-naming.ParameterMinimumLength,      value: '1' }

  # readability-braces-around-statements  (MISRA Rule 15.6)
  - { key: readability-braces-around-statements.ShortStatementLines,  value: '0' }

  # bugprone-narrowing-conversions: treat signed/unsigned mismatches
  - { key: bugprone-narrowing-conversions.WarnOnIntegerNarrowingConversion,     value: true }
  - { key: bugprone-narrowing-conversions.WarnOnIntegerToFloatingPointNarrowingConversion, value: true }
